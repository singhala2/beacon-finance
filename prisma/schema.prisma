// Beacon — database schema
// Phase 0: NextAuth-compatible identity tables only.
// Phase 1+ adds PlaidItem, Account (financial), Holding, Goal, Insight, Conversation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Onboarding profile fields
  firstName          String?
  age                Int?
  location           String?
  riskTolerance      Int?    // 1-5
  onboardingStep     Int     @default(0)  // 0 = welcome, 1-6 = steps, 7 = complete
  onboardingContext  String? @db.Text     // free-text from Step 6 audit

  // Dashboard customization (Phase 4). Null = use default layout.
  dashboardLayout    Json?

  // Phase 5: throttle for insight regeneration so cron + manual refresh don't double up
  lastInsightGeneratedAt DateTime?

  // Phase 7: clickwrap acceptance. acceptedTermsVersion mismatch with current
  // TERMS_VERSION constant triggers a re-prompt at next signin / page load.
  acceptedTermsAt      DateTime?
  acceptedTermsVersion String?

  authAccounts      AuthAccount[]
  sessions          Session[]
  plaidItems        PlaidItem[]
  financialAccounts FinancialAccount[]
  goals             Goal[]
  transactions      Transaction[]
  conversations     Conversation[]
  insights          Insight[]
  auditLogs         AuditLog[]
  documents         Document[]
  knowledgeFacts    KnowledgeFact[]
}

model Insight {
  id          String    @id @default(cuid())
  userId      String
  type        String    // idle_cash | match_gap | allocation_drift | fee_high | goal_behind | spend_spike | savings_opportunity | debt | other
  severity    String    // info | opportunity | attention
  headline    String
  body        String    @db.Text
  evidence    Json?     // [{ metric: string, value: number }]
  actions     Json?     // [{ id: string, label: string }]
  dismissedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissedAt, createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // 'user' | 'assistant' | 'system'
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Goal {
  id                  String    @id @default(cuid())
  userId              String
  name                String
  type                String    // emergency | house | retirement | debt | travel | custom
  targetAmount        Float?
  targetDate          DateTime?
  monthlyContribution Float?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt])
}

model PlaidItem {
  id              String   @id @default(cuid())
  userId          String
  plaidItemId     String   @unique
  accessToken     String   // AES-256-GCM encrypted
  institutionId   String?
  institutionName String?
  status          String   @default("active")
  cursor          String?  // incremental transaction sync cursor
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts FinancialAccount[]
}

model FinancialAccount {
  id               String   @id @default(cuid())
  userId           String
  plaidItemId      String?
  plaidAccountId   String?  @unique
  institution      String
  name             String
  mask             String?
  type             String   // depository | credit | investment | loan | other
  subtype          String?
  balanceCurrent   Float?
  balanceAvailable Float?
  balanceLimit     Float?
  currency         String   @default("USD")
  isHidden         Boolean  @default(false)
  customName       String?
  lastSyncedAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  item         PlaidItem?    @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  holdings     Holding[]
  transactions Transaction[]
}

model Transaction {
  id                 String   @id @default(cuid())
  userId             String
  accountId          String
  plaidTransactionId String   @unique
  date               DateTime
  amount             Float    // positive = outflow (Plaid convention)
  currency           String   @default("USD")
  name               String
  merchantName       String?
  category           String?  // Plaid PFC primary
  subcategory        String?  // Plaid PFC detailed
  pending            Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([accountId, date])
}

model Holding {
  id           String   @id @default(cuid())
  accountId    String
  securityId   String?
  symbol       String?
  name         String
  quantity     Float
  costBasis    Float?
  currentPrice Float?
  currentValue Float
  type         String   // equity | etf | mutual_fund | crypto | bond | cash | other
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

// NextAuth's "Account" table — provider-linked auth identity.
// Renamed to AuthAccount so it does not collide with Beacon's financial Account model in Phase 1.
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // e.g. plaid.item.connect, auth.signin, account.delete
  targetType String?  // e.g. PlaidItem, FinancialAccount, Goal
  targetId   String?
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// Phase 8 — Knowledge Hub.
// A source document the user uploaded (pay stub, offer letter, etc.).
// Facts are extracted from it; the document is provenance behind those facts.
model Document {
  id          String    @id @default(cuid())
  userId      String
  type        String    // registry DocumentType key: pay_stub | offer_letter | ...
  filename    String
  mimeType    String
  blobUrl     String?   @db.Text // legacy encrypted storage reference (Phase 8); superseded by objectKey
  objectKey   String?   @db.Text // R2 object key for the encrypted original (Phase 9); null when R2 not configured
  sizeBytes   Int?      // original byte size, for per-user quota (Phase 9)
  docKind     String?   // open-ended classification label, e.g. "will", "tax return" (Phase 9)
  summary     String?   @db.Text // redacted freeform key-takeaways summary (Phase 9)
  extractedText String? @db.Text // redacted full text, encrypted, for re-indexing (Phase 9)
  sourceExcerpt String? @db.Text // redacted provenance excerpt (PII stripped) when no raw blob is kept
  status      String    @default("processing") // processing | ready | failed
  error       String?   @db.Text
  uploadedAt  DateTime  @default(now())
  processedAt DateTime?

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  facts KnowledgeFact[]

  @@index([userId, uploadedAt])
}

// Phase 8 — the fact ledger. The unit of value in the Knowledge Hub.
// Flexible-but-typed: domain + key are validated against lib/knowledge/registry.ts
// at the app layer, so new fact types never need a migration.
model KnowledgeFact {
  id             String    @id @default(cuid())
  userId         String
  domain         String    // registry Domain key: income | debt | retirement | ...
  key            String    // registry FactType key: gross_annual_salary | ...
  valueJson      Json      // the typed value payload
  valueType      String    // money | text | enum | date | number | boolean
  source         String    // document | chat | manual | plaid | system
  documentId     String?
  confidence     Float?    // 0..1; null for user-entered
  status         String    @default("pending") // pending | confirmed | rejected
  effectiveDate  DateTime?
  expiresAt      DateTime?
  supersededById String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  document     Document?       @relation(fields: [documentId], references: [id], onDelete: SetNull)
  supersededBy KnowledgeFact?  @relation("Supersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes   KnowledgeFact[] @relation("Supersession")

  @@index([userId, domain, status])
  @@index([userId, key, status])
}
