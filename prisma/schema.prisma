// Beacon — database schema
// Phase 0: NextAuth-compatible identity tables only.
// Phase 1+ adds PlaidItem, Account (financial), Holding, Goal, Insight, Conversation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Onboarding profile fields
  firstName          String?
  age                Int?
  location           String?
  riskTolerance      Int?    // 1-5
  onboardingStep     Int     @default(0)  // 0 = welcome, 1-6 = steps, 7 = complete
  onboardingContext  String? @db.Text     // free-text from Step 6 audit

  accounts AuthAccount[]
  sessions Session[]
}

// NextAuth's "Account" table — provider-linked auth identity.
// Renamed to AuthAccount so it does not collide with Beacon's financial Account model in Phase 1.
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
