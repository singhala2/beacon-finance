# Beacon — environment variables
# Copy to .env.local and fill in real values.

# ── Database ────────────────────────────────────────────────────
# Recommended: Neon (https://neon.tech) — free tier, serverless Postgres.
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# ── Auth.js ─────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=
# Public URL of the app. http://localhost:3000 for dev.
NEXTAUTH_URL=http://localhost:3000

# ── Resend (magic-link email delivery) ──────────────────────────
# Sign up at https://resend.com — free tier covers dev.
AUTH_RESEND_KEY=
# Verified sender, e.g. "Beacon <login@your-domain.com>" — use onboarding@resend.dev for dev
AUTH_EMAIL_FROM=onboarding@resend.dev
